generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id           Int      @id @default(autoincrement())
  customerId   Int?
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerName String
  phone        String
  houseNo      String
  moo          String?
  soi          String?
  subDistrict  String
  district     String
  province     String
  postalCode   String
  lineId       String?
  productName  String
  color        String
  size         String
  quantity     Int      @default(1)
  totalPrice   Float
  status       String   @default("pending")
  note         String?
  secureToken  String?  @unique
  lineUid      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LineUser {
  uid         String   @id
  lastActive  DateTime @default(now())
}

model audit_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String   @db.VarChar(255)
  details    Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "audit_logs_user_id_users_id_fk")
}

model expense_categories {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  group_name String     @db.VarChar(50)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  expenses   expenses[]
}

model expenses {
  id                 Int                @id @default(autoincrement())
  category_id        Int
  product_id         Int?
  description        String?
  amount             Decimal            @db.Decimal(12, 2)
  quantity           Int                @default(1)
  cost_per_unit      Decimal?           @db.Decimal(12, 2)
  receipt_path       String?            @db.VarChar(500)
  is_cleared         Boolean            @default(false)
  expense_date       DateTime           @default(now()) @db.Date
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  expense_categories expense_categories @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "expenses_category_id_expense_categories_id_fk")
  products           products?          @relation(fields: [product_id], references: [id], onUpdate: NoAction, map: "expenses_product_id_products_id_fk")
}

model income {
  id               Int            @id @default(autoincrement())
  product_id       Int
  channel_id       Int
  quantity         Int            @default(1)
  full_price       Decimal        @db.Decimal(12, 2)
  discount_percent Decimal        @default(0) @db.Decimal(5, 2)
  net_amount       Decimal        @db.Decimal(12, 2)
  discount_amount  Decimal        @default(0) @db.Decimal(12, 2)
  cash_flow_status String         @default("pending") @db.VarChar(20)
  is_cleared       Boolean        @default(false)
  sale_date        DateTime       @default(now()) @db.Date
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @db.Timestamptz(6)
  sales_channels   sales_channels @relation(fields: [channel_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "income_channel_id_sales_channels_id_fk")
  products         products       @relation(fields: [product_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "income_product_id_products_id_fk")
}

model product_categories {
  id         Int        @id @default(autoincrement())
  name       String     @unique(map: "product_categories_name_unique") @db.VarChar(100)
  slug       String     @unique(map: "product_categories_slug_unique") @db.VarChar(100)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  products   products[]
}

model products {
  id                 Int                 @id @default(autoincrement())
  name               String              @db.VarChar(255)
  category_id        Int?
  base_cost          Decimal             @default(0) @db.Decimal(12, 2)
  is_archived        Boolean             @default(false)
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  expenses           expenses[]
  income             income[]
  product_categories product_categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "products_category_id_product_categories_id_fk")
}

model sales_channels {
  id         Int      @id @default(autoincrement())
  name       String   @unique(map: "sales_channels_name_unique") @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  income     income[]
}

model settings {
  id         Int      @id @default(autoincrement())
  key        String   @unique(map: "settings_key_unique") @db.VarChar(100)
  value      Json
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model users {
  id         Int          @id @default(autoincrement())
  username   String       @unique(map: "users_username_unique") @db.VarChar(100)
  role       String       @default("staff") @db.VarChar(20)
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  audit_logs audit_logs[]
}
